# Ignore auto-generated files and common build/IDE artifacts

# OS
.DS_Store
Thumbs.db

# Node/npm/Yarn
node_modules/
.npm/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp.*

# Build / distribution / caches
dist/
build/
out/
public/           # static site generators (Gatsby, Hugo, etc.)
docs/             # sometimes used for generated docs
.next/
.nuxt/
.svelte-kit/
.cache/
.cache-loader/
.parcel-cache/

# Logs and reports
*.log
logs/
pids/
*.pid
*.seed
*.pid.lock
coverage/
.nyc_output/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.env
.env.*.local
pip-wheel-metadata/
*.egg-info/
.eggs/

# Java / JVM
target/
*.class
*.jar
*.war
*.ear
.idea/
*.iml

# Gradle / Maven
.gradle/
build/

# .NET
bin/
obj/
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Go
vendor/
*.exe
*.dll
*.so
*.dylib

# IDEs and editors
.vscode/
.idea/
*.swp
*~
*.sublime-workspace
*.sublime-project

# Containers / env
.env
.env.local
.env.*.local
docker-compose.override.yml
.Dockerfile*
# Legacy host-mounted Nacos data directory (still auto-generated locally)
nacos_data/

# Temporary / backup files
*.tmp
*.bak

# Generated key/cert files
*.key
*.crt

*.dat 
